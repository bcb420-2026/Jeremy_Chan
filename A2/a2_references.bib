  @ARTICLE{10.3389/fcell.2022.962481,
    AUTHOR={Wang, Maoyu  and Shen, Sen  and Hou, Feng  and Yan, Yaohua },
    TITLE={Pathophysiological roles of integrins in gliomas from the perspective of glioma stem cells},
    JOURNAL={Frontiers in Cell and Developmental Biology},
    VOLUME={Volume 10 - 2022},
    YEAR={2022},
    URL={https://www.frontiersin.org/journals/cell-and-developmental-biology/articles/10.3389/fcell.2022.962481},
    DOI={10.3389/fcell.2022.962481},
    ISSN={2296-634X},
    ABSTRACT={Glioblastoma is the most common primary intracranial tumour and is also one of the most malignant central nervous system tumours. Its characteristics, such as high malignancy, abundant tumour vasculature, drug resistance, and recurrence-prone nature, cause great suffering to glioma patients. Furthermore, glioma stem cells are the primordial cells of the glioma and play a central role in the development of glioma. Integrins—heterodimers composed of noncovalently bound α and β subunits—are highly expressed in glioma stem cells and play an essential role in the self-renewal, differentiation, high drug resistance, and chemo-radiotherapy resistance of glioma stem cells through cell adhesion and signalling. However, there are various types of integrins, and their mechanisms of function on glioma stem cells are complex. Therefore, this paper reviews the feasibility of treating gliomas by targeting integrins on glioma stem cells.}
  }
